{
  "brackets": [
    ["(", ")"]
  ],

  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],

  "surroundingPairs": [
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],

  "indentationRules": {
    "increaseIndentPattern": {
      "pattern": "^\\s*(if|for|while|repeat|select|when|FuncBegin)\\b",
      "flags": "i"
    },
    "decreaseIndentPattern": {
      "pattern": "^\\s*(else|endif|next|endwhile|endrep|endselect|FuncEnd)\\b",
      "flags": "i"
    }
  },
  
  "onEnterRules": [
    {
      "beforeText": { "pattern": "^\\s*(if|else|for|while|select|when|repeat)\\b", "flags": "i" },
      "action": {
        "indent": "none",
        "appendText": "  "
      }
    },
    {
      "beforeText": { "pattern": "^\\s*funcbegin\\b", "flags": "i" },
      "action": {
        "indent": "none",
        "appendText": "     "
      }
    }
  ]
}