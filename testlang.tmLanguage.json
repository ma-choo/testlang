{
  "name": "Machoo",
  "scopeName": "source.testlang",

  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },

    { "include": "#functions" },
    { "include": "#labels" },

    { "include": "#keywords" },

    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],

  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.exclamation.machoo",
          "match": "!.*$"
        },
        {
          "name": "comment.line.underscore.machoo",
          "match": "_.*$"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.machoo",
          "match": "(?i)(?<![A-Za-z0-9])(if|and|or|then|else|endif|while|endwhile|for|next|select|when|endselect|return|continue|ifndef|define|again)(?![A-Za-z0-9])"
        },
        {
          "name": "keyword.modifier.machoo",
          "match": "(?i)(?<![A-Za-z0-9])(length|set|setuniq|local|common|format|clear)(?![A-Za-z0-9])"
        },
        {
          "name": "keyword.filesystem.machoo",
          "match": "(?i)(?<![A-Za-z0-9])(file|close|key|ind)(?![A-Za-z0-9])"
        },
        {
          "name": "keyword.function.machoo",
          "match": "(?i)(?<![A-Za-z0-9])(FuncProto|FuncEnd)(?![A-Za-z0-9])"
        },
        {
          "name": "support.class.goto.machoo",
          "match": "(?i)(?<![A-Za-z0-9])(goto|go|gosub|excp|excpsub)(?![A-Za-z0-9])"
        },
        {
          "name": "constant.language.machoo",
          "match": "(?i)(?<![A-Za-z0-9])(true|false)(?![A-Za-z0-9])"
        }
      ]
    },

    "labels": {
      "patterns": [
        {
          "name": "constant.numeric.label.define.machoo",
          "match": "(?<![A-Za-z0-9])[A-Za-z][A-Za-z0-9]*(?=:)"
        },
        {
          "name": "constant.numeric.label.reference.machoo",
          "match": "(?i)(?<=\\b(goto|go|gosub|excp|excpsub)\\s)(?<![A-Za-z0-9])[A-Za-z][A-Za-z0-9]*(?![A-Za-z0-9])"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.machoo",
          "match": "(?i)(?<![A-Za-z0-9])(funcbegin)\\s+([A-Za-z][A-Za-z0-9]*)",
          "captures": {
            "1": { "name": "keyword.control.funcbegin.machoo" },
            "2": { "name": "entity.name.function.machoo" }
          }
        },
        {
          "name": "meta.function.call.machoo",
          "begin": "(?<![A-Za-z0-9])([A-Za-z][A-Za-z0-9]*)\\s*\\(",
          "beginCaptures": {
            "1": { "name": "entity.name.function.machoo" },
            "0": { "name": "meta.function.call.machoo" }
          },
          "end": "\\)",
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#keywords" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.machoo",
          "match": "[;,_]"
        },
        {
          "name": "punctuation.section.parens.begin.machoo",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.machoo",
          "match": "\\)"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.machoo",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.machoo" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.machoo" }
          },
          "patterns": [
            {
              "match": "\"\"",
              "name": "constant.character.escape.machoo"
            }
          ]
        },
        {
          "name": "string.quoted.single.machoo",
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.machoo" }
          },
          "end": "'",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.machoo" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.machoo",
          "match": "(?i)(?<![A-Za-z0-9])(eq|ne|gt|lt|ge|le)(?![A-Za-z0-9])"
        },
        {
          "name": "keyword.operator.symbol.machoo",
          "match": "[-+*/=<>&|]+"
        },
        {
          "name": "keyword.operator.symbol.machoo",
          "match": "[@]+"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.machoo",
          "match": "(?<![A-Za-z0-9])\\d+(\\.\\d+)?(?![A-Za-z0-9])"
        }
      ]
    }
  }
}